{
  "name": "hotel-management-system",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "npx tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rimraf dist dist_desktop dist_server",
    "lint": "tsc --noEmit",
    "build:server": "esbuild server.ts --bundle --platform=node --outfile=dist_server/server.cjs --format=cjs --external:electron --external:vite --external:better-sqlite3 --external:bcrypt",
    "desktop": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build:exe": "npm run clean && npm run build && npm run build:server && electron-builder build --win --publish never"
  },
  "build": {
    "appId": "com.hotelmanagementsystem.app",
    "productName": "Hotel Management System",
    "directories": {
      "output": "dist_desktop"
    },
    "files": [
      "dist/**/*",
      "dist_server/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "icon": "public/icon.ico"
    }
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.104.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.0",
    "express": "^4.22.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "rimraf": "^6.1.3",
    "typescript": "~5.8.2",
    "wait-on": "^9.0.5"
  }
}
